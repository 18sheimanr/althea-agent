# Local app config
PORT=8080
GCP_PROJECT_ID=your-gcp-project-id
FIRESTORE_COLLECTION=poc_requests
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_ALLOWED_FROM=+15555550100
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
CONVERSATIONS_COLLECTION=agent_conversations
EVENTS_COLLECTION=agent_events
EVENT_HOOK_TOKEN=optional-internal-hook-secret
INTERNAL_HOOK_AUDIENCE=https://your-cloud-run-url/internal/events/agent-hook
TASKS_CALLER_SERVICE_ACCOUNT=tasks-caller@your-project.iam.gserviceaccount.com
GOOGLE_SEARCH_API_KEY=optional-google-search-key
GOOGLE_SEARCH_CX=optional-custom-search-engine-id

# Cloud Run naming (used as GitHub Repository Variables)
GCP_REGION=us-central1
CLOUD_RUN_SERVICE_NAME=althea-poc-api
