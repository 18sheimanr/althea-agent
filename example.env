# Local app config
PORT=8080
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_ALLOWED_FROM=+15555550100
GEMINI_MODEL=gemini-2.5-flash
CONVERSATIONS_COLLECTION=agent_conversations
EVENTS_COLLECTION=agent_events
INTERNAL_HOOK_AUDIENCE=https://your-cloud-run-url/internal/events/agent-hook
TASKS_CALLER_SERVICE_ACCOUNT=tasks-caller@your-project.iam.gserviceaccount.com
TASKS_QUEUE_ID=athena-reminders
TASKS_LOCATION=us-central1
TWILIO_FROM_NUMBER=+15551234567
TWILIO_MESSAGING_SERVICE_SID=optional-messaging-service-sid

# Cloud Run naming (used as GitHub Repository Variables)
GCP_REGION=us-central1
CLOUD_RUN_SERVICE_NAME=althea-poc-api
